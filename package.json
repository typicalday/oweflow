{
  "name": "owenwork",
  "version": "0.1.0",
  "description": "owenwork — a debt-driven dataflow engine for agent workflows. Steps fire on what they owe, not a status; the graph stays honest with its live inputs and knows when to stop. The deterministic rails your probabilistic agents run on — the part of your owen loop that doesn't hallucinate. Direct node:sqlite (WAL + commit-fingerprint CAS).",
  "license": "Apache-2.0",
  "author": "typicalday",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typicalday/owenwork.git"
  },
  "homepage": "https://github.com/typicalday/owenwork#readme",
  "bugs": {
    "url": "https://github.com/typicalday/owenwork/issues"
  },
  "keywords": [
    "workflow",
    "dataflow",
    "engine",
    "sqlite",
    "orchestration",
    "dag",
    "state-machine",
    "agents",
    "ai-agents",
    "determinism",
    "owen-loop"
  ],
  "bin": {
    "owenwork": "bin/owenwork.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "bin",
    "examples",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "owenwork": "node bin/owenwork.mjs",
    "test": "node --test --test-reporter=spec test/*.test.ts",
    "test:quiet": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test:quiet",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.6"
  }
}
